# Arabic Sign Language System — Environment Variables
# Copy this file to .env and fill in your values.

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=INFO

# ── NLP ───────────────────────────────────────────────────────
# Set to "true" to enable AraBERT grammar correction (requires transformers)
USE_ARABERT=false

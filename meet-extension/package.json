{
  "name": "meet-asl-translator",
  "displayName": "Meet ASL Translator",
  "version": "0.0.1",
  "description": "ASL Translator for Google Meet using MediaPipe and Fingerpose",
  "author": "Adel Hefny",
  "scripts": {
    "sync-assets": "xcopy /Y /I /E assets\\tasks-vision-wasm build\\chrome-mv3-dev\\assets\\tasks-vision-wasm\\ && copy /Y assets\\holistic_landmarker.task build\\chrome-mv3-dev\\assets\\holistic_landmarker.task",
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "dev:edge": "plasmo dev --target=edge-mv3",
    "build:edge": "plasmo build --target=edge-mv3",
    "package:edge": "plasmo package --target=edge-mv3"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "latest",
    "@plasmohq/messaging": "^0.7.2",
    "onnxruntime-node": "^1.25.1",
    "onnxruntime-web": "^1.25.1",
    "plasmo": "latest",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "latest",
    "@types/chrome": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "prettier": "latest",
    "svgo": "^3.3.4",
    "typescript": "latest"
  },
  "manifest": {
    "host_permissions": [
      "https://meet.google.com/*"
    ],
    "permissions": [
      "offscreen"
    ],
    "web_accessible_resources": [
      {
        "resources": [
          "assets/ort-wasm/*",
          "assets/*.onnx",
          "assets/*.json",
          "assets/tasks-vision-wasm/*",
          "assets/*.task"
        ],
        "matches": [
          "<all_urls>"
        ]
      }
    ],
    "content_security_policy": {
      "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
    }
  }
}

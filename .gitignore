*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────
venv/
.venv/
env/

# ── Environment / secrets ─────────────────────────────────────
.env
*.env

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Data (large files — track with Git LFS if needed) ─────────
data/raw/*
data/processed/*
data/landmarks/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/landmarks/.gitkeep

datasets/raw/*
datasets/processed/*
datasets/landmarks/*
datasets/tfrecords/*
!datasets/raw/.gitkeep
!datasets/processed/.gitkeep
!datasets/landmarks/.gitkeep
!datasets/tfrecords/.gitkeep

# ── Logs ──────────────────────────────────────────────────────
logs/

# ── Model checkpoints (track ONNX finals, not .pt checkpoints) ─
models/checkpoints/
models/onnx/
models/quantized/
models/optimised/
*.pt
*.pth

